# Token do bot — obtenha com @BotFather no Telegram
TELEGRAM_BOT_TOKEN=seu_token_aqui

# Chave da API da Anthropic (Claude)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Token da API do Vercel — para buscar o domínio de produção
# Crie em: https://vercel.com/account/tokens
VERCEL_TOKEN=seu_token_aqui

# GitHub Personal Access Token — necessário para git push no Railway
# Crie em: https://github.com/settings/tokens (permissão: repo)
GIT_TOKEN=ghp_...

# Git — identidade para commits automáticos (opcional, tem padrão)
GIT_USER_NAME=Flip7Custom Bot
GIT_USER_EMAIL=bot@flip7custom.local

# Chave da OpenAI — para transcrição de áudios via Whisper
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
